# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hajime_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication Secrets (generate with: openssl rand -base64 64)
ACCESS_TOKEN_SECRET=change_me_in_production_access_token_secret
REFRESH_TOKEN_SECRET=change_me_in_production_refresh_token_secret
SESSION_SECRET=change_me_in_production_session_secret

# Application
NODE_ENV=development
PORT=4242
CLIENT_URL=http://localhost:8080

# Feature Flags
FEATURE_FLAG_AUTH_ENABLED=true
FEATURE_FLAG_CSV_ENABLED=true
FEATURE_FLAG_DB_MIGRATION_STAGE=3

# Stripe (existing)
STRIPE_SECRET_KEY=
ALLOWED_ORIGINS=
