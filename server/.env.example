# Copy to server/.env — never commit .env
# Keys must match mode: sk_test_ with VITE pk_test_, sk_live_ with VITE pk_live_
# https://dashboard.stripe.com/apikeys
#
# Customer “save card” links use Stripe Checkout (setup). In live mode, add your app URL under
# Stripe Dashboard → Settings → Checkout → Customer-facing URLs (success/cancel redirects).

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PORT=4242

# Production: browser origins allowed to use the API (comma-separated, no trailing slash).
# Example: ALLOWED_ORIGINS=https://drinkhajime.jp,https://www.drinkhajime.jp
# ALLOWED_ORIGINS=
