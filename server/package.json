{
  "name": "hajime-api",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node index.mjs",
    "start:legacy": "node -e \"console.error('start:legacy is deprecated and hard-disabled. Do not run server/stripe-server.mjs in normal flow.'); process.exit(1)\"",
    "migrate": "knex migrate:latest --knexfile knexfile.mjs",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.mjs",
    "migrate:make": "knex migrate:make --knexfile knexfile.mjs",
    "seed": "knex seed:run --knexfile knexfile.mjs",
    "db:reset": "npm run migrate:rollback && npm run migrate && npm run seed",
    "test:integration": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "bullmq": "^5.73.0",
    "compression": "^1.7.5",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.9",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.20.0",
    "stripe": "^17.7.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}
